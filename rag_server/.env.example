# ── rag_server — настройки ────────────────────────────────────────────────────
# Remote HTTP-сервер. Принимает запросы от mcp_server (gateway).
# Для запуска: bash rag_server/start_rag.sh

# Сетевой интерфейс и порт
RAG_HOST=0.0.0.0
RAG_PORT=8000

# Conda env (должен совпадать с именем в environment.yml)
ENV_NAME=mcp-rag

# ── Подключение к embed_server ────────────────────────────────────────────────
# Один воркер (по умолчанию):
EMBED_SERVER_URL=http://127.0.0.1:8001
# Несколько воркеров — батч делится поровну, вызовы параллельны.
# При наличии EMBED_SERVER_URLS значение EMBED_SERVER_URL игнорируется.
# EMBED_SERVER_URLS=http://127.0.0.1:8001,http://gpu-host:8001

# Максимум символов на чанк перед отправкой в embed_server
EMBED_MAX_CHARS=4000

# Размер батча при отправке в embed_server (чанков за один HTTP-запрос)
EMBED_BATCH_SIZE=16

# ── Хранилище проектов ────────────────────────────────────────────────────────

# ── Настройки инжеста ─────────────────────────────────────────────────────────
AUTO_INGEST_MAX_FILE_BYTES=800000
AUTO_INGEST_ALLOWLIST=
AUTO_INGEST_EXTENSIONS=.py,.md,.txt,.json,.yaml,.yml,.toml,.ini,.js,.ts,.tsx,.css,.html

# ── Поиск ─────────────────────────────────────────────────────────────────────
HYBRID_SEARCH_ENABLED=false

# ── Watchdog (FS watcher) — отключён по умолчанию ────────────────────────────
# При больших проектах расходует inotify watches и вызывает зависания.
# Изменения отслеживаются только при явном вызове incremental ingest.
FS_WATCHER_ENABLED=false

# ── Reranker (опционально — требует sentence-transformers) ────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
