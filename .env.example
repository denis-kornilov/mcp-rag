# mcp-rag — конфигурация для локального запуска всех компонентов на одной машине
#
# Использование:
#   cp .env.example .env
#
# Для тонкой настройки каждого компонента используйте .env в папке подсистемы:
#   embed_server/.env  — модель, потоки, GPU
#   rag_server/.env    — порт, ChromaDB, параметры инжеста
#   mcp_server/.env    — транспорт, адрес rag_server
#
# Настройки из корневого .env применяются как дефолты.
# Подсистемные .env переопределяют их при совпадении имён переменных.

# ══════════════════════════════════════════════════════════════════════════════
# embed_server (порт 8001) — сервер векторизации ONNX BGE-M3
# ══════════════════════════════════════════════════════════════════════════════

# Сетевой интерфейс embed_server
# 0.0.0.0 — доступен извне (для remote setup)
# 127.0.0.1 — только localhost
EMBED_HOST=0.0.0.0
EMBED_PORT=8001

# Вычислительный бэкенд для ONNX Runtime:
#   onnx-cpu  — CPU INT8 (работает везде, рекомендуется по умолчанию)
#   onnx-cuda — NVIDIA GPU (требует onnxruntime-gpu и CUDA драйвер)
#   onnx-rocm — AMD GPU  (требует onnxruntime-rocm и ROCm)
#   onnx-auto — GPU если доступен, иначе CPU автоматически
EMBED_BACKEND=onnx-cpu

# Потоки ORT для инжеста (каждый поток = одно ядро CPU внутри одной ORT-сессии)
# Рекомендуется: количество физических ядер / 2, но не более 8
ONNX_NUM_THREADS=4

# Потоки ORT для поиска — отдельная параллельная сессия, не конкурирует с инжестом
# Для поискового запроса одного ядра достаточно (запрос короткий)
SEARCH_THREADS=1

# Параллелизм между операциями ORT-графа (inter-op parallelism)
# 1 — рекомендуется для CPU и GPU (граф BGE-M3 в основном линейный)
# >1 имеет смысл только при ONNX_EXECUTION_MODE=parallel
ONNX_INTER_THREADS=1

# Режим выполнения ORT-графа: sequential | parallel
# sequential — подходит для всех режимов и даёт предсказуемую латентность
ONNX_EXECUTION_MODE=sequential

# Выбор конкретного GPU-устройства при наличии нескольких GPU в системе
# (только для EMBED_BACKEND=onnx-cuda или onnx-rocm)
# 0 — первый GPU (по умолчанию); 1 — второй GPU и т.д.
CUDA_DEVICE_ID=0
ROCM_DEVICE_ID=0

# Максимальный батч чанков за один вызов encode()
EMBED_BATCH_SIZE=32

# Максимальная длина последовательности токенов (BGE-M3 поддерживает до 8192)
# 512 — хороший баланс между качеством и скоростью
EMBED_MAX_SEQ_LEN=512

# ══════════════════════════════════════════════════════════════════════════════
# rag_server (порт 8000) — API сервер RAG + ChromaDB
# ══════════════════════════════════════════════════════════════════════════════

# Сетевой интерфейс rag_server
RAG_HOST=0.0.0.0
RAG_PORT=8000

# Адрес embed_server (один воркер)
EMBED_SERVER_URL=http://127.0.0.1:8001

# Несколько embed_server воркеров — батч делится поровну, вызовы параллельны.
# При наличии этой переменной EMBED_SERVER_URL игнорируется.
# EMBED_SERVER_URLS=http://127.0.0.1:8001,http://gpu-host:8001

# Максимум символов на чанк перед отправкой в embed_server
EMBED_MAX_CHARS=4000

# Размер батча при отправке чанков в embed_server (чанков за один HTTP-запрос)
EMBED_BATCH_SIZE=16

# Максимальный размер файла для инжеста (байты). Большие файлы пропускаются.
AUTO_INGEST_MAX_FILE_BYTES=800000

# Расширения файлов для индексации (через запятую)
AUTO_INGEST_EXTENSIONS=.py,.md,.txt,.json,.yaml,.yml,.toml,.ini,.js,.ts,.tsx,.css,.html

# Дополнительные пути/паттерны для индексации (glob, через запятую).
# Пусто = индексировать весь проект по AUTO_INGEST_EXTENSIONS.
# Пример: src/,docs/,*.md
AUTO_INGEST_ALLOWLIST=

# Гибридный поиск: BM25 + векторный поиск с RRF (Reciprocal Rank Fusion)
# false — только векторный поиск (быстрее)
# true  — BM25 + вектор (точнее для конкретных имён функций/переменных)
HYBRID_SEARCH_ENABLED=false

# FS Watcher (watchdog) — отслеживание изменений файлов в реальном времени
# ВНИМАНИЕ: при больших проектах расходует inotify watches и вызывает зависания.
# Рекомендуется оставить false — инкрементальный инжест запускается явно через MCP.
# false — отключён (рекомендуется)
# true  — включён (только для небольших проектов)
FS_WATCHER_ENABLED=false

# Модель cross-encoder reranker (опционально — требует sentence-transformers)
# pip install sentence-transformers
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ══════════════════════════════════════════════════════════════════════════════
# mcp_server / gateway (порт 8002) — MCP шлюз
# ══════════════════════════════════════════════════════════════════════════════

# Транспорт MCP (как IDE подключается к gateway):
#   http  — gateway запускается независимо (start_mcp.sh), IDE подключается по HTTP
#   stdio — gateway запускается IDE как дочерний процесс (не нужен отдельный сервер)
MCP_TRANSPORT=http

# Адрес и порт MCP gateway (только для http транспорта)
MCP_HOST=127.0.0.1
MCP_PORT=8002

# RAG режим работы gateway:
#   http  — gateway подключается к отдельному rag_server по HTTP (продакшн)
#   local — rag_server запускается внутри процесса gateway (разработка/простой деплой)
RAG_BACKEND=http

# Адрес rag_server (только для RAG_BACKEND=http)
RAG_SERVER=http://127.0.0.1:8000

# Интервал проверки доступности rag_server при старте (секунды)
RAG_CONNECT_POLL_S=10

# ══════════════════════════════════════════════════════════════════════════════
# Общие настройки
# ══════════════════════════════════════════════════════════════════════════════

# Отключить телеметрию ChromaDB
ANONYMIZED_TELEMETRY=false
