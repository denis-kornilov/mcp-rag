# ── embed_server — настройки ─────────────────────────────────────────────────
# Сервер векторизации. Принимает запросы от rag_server по HTTP.
# Для запуска: bash embed_server/start_embed.sh

# Сетевой интерфейс и порт
EMBED_HOST=0.0.0.0
EMBED_PORT=8001

# Conda env (должен совпадать с именем в environment.yml)
ENV_NAME=mcp-embed

# ── Модель ────────────────────────────────────────────────────────────────────
# Вычислительный бэкенд:
#   onnx-cpu  — ONNX Runtime INT8 CPU (по умолчанию, всегда работает)
#   onnx-cuda — ONNX Runtime CUDA    (NVIDIA, требует onnxruntime-gpu)
#   onnx-rocm — ONNX Runtime ROCm    (AMD, требует onnxruntime-rocm)
#   onnx-auto — GPU если доступен, иначе CPU
EMBED_BACKEND=onnx-cpu

# ── Потоки и батчи ────────────────────────────────────────────────────────────
# Потоки ORT для инжеста (intra-op — параллелизм внутри одной операции)
ONNX_NUM_THREADS=4

# Потоки ORT для поиска (отдельная параллельная сессия)
SEARCH_THREADS=1

# Потоки ORT между операциями графа (inter-op parallelism)
# 1 — для CPU (последовательный граф); >1 только при ONNX_EXECUTION_MODE=parallel
ONNX_INTER_THREADS=1

# Режим выполнения ORT-графа: sequential | parallel
# sequential — рекомендуется для CPU и GPU
ONNX_EXECUTION_MODE=sequential

# ── GPU ────────────────────────────────────────────────────────────────────────
# ID GPU-устройства для NVIDIA (EMBED_BACKEND=onnx-cuda)
# 0 — первый GPU; 1 — второй GPU и т.д.
CUDA_DEVICE_ID=0

# ID GPU-устройства для AMD (EMBED_BACKEND=onnx-rocm)
ROCM_DEVICE_ID=0

# Максимальный батч на один вызов encode()
EMBED_BATCH_SIZE=32

# Максимальная длина последовательности токенов
EMBED_MAX_SEQ_LEN=512
