# ── mcp_server — настройки ────────────────────────────────────────────────────
# MCP сервер запускается независимо (start_mcp.sh).
# IDE подключается к нему по HTTP. MCP сервер сам является RAG клиентом.

# ── MCP сервер (куда подключается IDE) ───────────────────────────────────────
MCP_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PORT=8002

# ── RAG клиент (куда подключается этот сервер) ───────────────────────────────
RAG_BACKEND=http
RAG_SERVER=http://127.0.0.1:8000

# Интервал проверки соединения с rag_server (секунды)
RAG_CONNECT_POLL_S=10

# Multi-project (опционально)
# PROJECT_KEY=<your-project-key>
# SERVER_DATA_ROOT=./data/projects
