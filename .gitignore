data/chroma_db/
# Legacy path
.mcp_rag/

# ── ML models and caches ────────────────────────────────────────────────────────
# HuggingFace models (4+ GB)
data/hf_home/
embed_server/data/
# ONNX exports (generated from HF models)
onnx_exports/
# PyTorch / HF caches
.cache/
*.pt
*.bin
*.safetensors
*.onnx
# Exception: if you want to commit small quantized models — comment out the line above

# ── Logs ──────────────────────────────────────────────────────────────────────
